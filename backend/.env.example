# 動作モード: true の場合は外部API(eBay等)を呼ばずJSON生成で完結
TEST_MODE=true

# データベース接続 (docker-compose のサービス名 db を利用)
DB_HOST=db
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app_password
DB_NAME=amazon_ebay

# CORS 許可オリジン
FRONTEND_ORIGIN=http://localhost:3000

# --- 以下は後続フェーズで使用 (今は空でOK) ---
# eBay Developer API
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_OAUTH_TOKEN=

# AI (英語タイトル/説明生成) 例: OpenAI
OPENAI_API_KEY=

# Amazon 商品取得 (実装方法は後で選定)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
