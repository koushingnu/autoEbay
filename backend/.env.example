# 動作モード: true の場合は eBay 等の外部APIを呼ばずモックで完結（実出品しない安全装置）
TEST_MODE=true

# データベース接続 (docker-compose のサービス名 db を利用)
DB_HOST=db
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app_password
DB_NAME=amazon_ebay

# CORS 許可オリジン
FRONTEND_ORIGIN=http://localhost:3000

# 簡易ログイン（単一ユーザー）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SESSION_SECRET=please-change-this-secret

# --- 以下は後続フェーズで使用 ---
# eBay Developer API（実際の値は .env に記入すること。ここには書かない）
# sandbox で接続確認するには TEST_MODE=false + EBAY_APP_ID/EBAY_CERT_ID + EBAY_ENV=sandbox
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_OAUTH_TOKEN=       # 実出品に必要なユーザートークン(本人同意で発行)
EBAY_ENV=sandbox        # sandbox / production
USD_JPY_RATE=150        # eBay価格のUSD換算に使用する為替(1USD=xxJPY)

# eBay 出品設定（Sell API）。ポリシーIDは空なら既存の先頭を自動採用
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CURRENCY=USD
EBAY_MERCHANT_LOCATION_KEY=WAREHOUSE1   # 在庫ロケーション（自動作成）
EBAY_CATEGORY_ID=171485                 # 既定カテゴリ
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=

# AI (英語タイトル/説明生成) 例: OpenAI
OPENAI_API_KEY=

# Amazon 商品取得: Keepa API
# 実データを取得するには KEEPA_API_KEY を設定
KEEPA_API_KEY=
KEEPA_DOMAIN=5  # 5 = amazon.co.jp（日本）
