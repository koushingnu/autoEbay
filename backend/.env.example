# 動作モード: true の場合は外部API(eBay等)を呼ばずJSON生成で完結
TEST_MODE=true

# データベース接続 (docker-compose のサービス名 db を利用)
DB_HOST=db
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app_password
DB_NAME=amazon_ebay

# CORS 許可オリジン
FRONTEND_ORIGIN=http://localhost:3000

# 簡易ログイン（単一ユーザー）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SESSION_SECRET=please-change-this-secret

# --- 以下は後続フェーズで使用 (今は空でOK) ---
# eBay Developer API
# 実出品には TEST_MODE=false かつ EBAY_APP_ID/EBAY_CERT_ID が必要
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_OAUTH_TOKEN=
EBAY_ENV=sandbox        # sandbox / production
USD_JPY_RATE=150        # eBay価格のUSD換算に使用する為替(1USD=xxJPY)

# AI (英語タイトル/説明生成) 例: OpenAI
OPENAI_API_KEY=

# Amazon 商品取得: Keepa API
# 実データを取得するには TEST_MODE=false かつ KEEPA_API_KEY を設定
KEEPA_API_KEY=
KEEPA_DOMAIN=5  # 5 = amazon.co.jp（日本）
